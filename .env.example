# Local PostgreSQL service used by docker compose.
ASTERIA_POSTGRES_USER=asteria
ASTERIA_POSTGRES_PASSWORD=asteria
ASTERIA_POSTGRES_DB=asteria
ASTERIA_POSTGRES_PORT=5432

# Local API database URL. Keep this in sync with the PostgreSQL settings above.
ASTERIA_API_DATABASE_URL=postgresql+psycopg://asteria:asteria@127.0.0.1:5432/asteria
