# Local API service settings
ASTERIA_API_APP_NAME="Asteria API"
ASTERIA_API_ENVIRONMENT="development"
ASTERIA_API_HOST="127.0.0.1"
ASTERIA_API_PORT="8000"
ASTERIA_API_CORS_ORIGINS="http://localhost:1420,http://127.0.0.1:1420,http://localhost:5173,http://127.0.0.1:5173"

# Local development database URL for the Docker Compose db service.
ASTERIA_API_DATABASE_URL="postgresql+psycopg://asteria:asteria@127.0.0.1:5432/asteria"

# Fernet key used to encrypt Provider API keys in ai_providers.api_key_ciphertext.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ASTERIA_API_SECRET_KEY=""
